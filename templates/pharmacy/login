<h2>Medicare Login</h2>

{% if form.errors %}
  <p style="color:red">Wrong username or password.</p>
{% endif %}

<form method="post">
  {% csrf_token %}
  {{ form.as_p }}
  <button type="submit">Log In</button>
</form>

<p><a href="{% url 'password_reset' %}">Forgot password?</a></p>
<p><a href="/">Back to Home</a></p>
